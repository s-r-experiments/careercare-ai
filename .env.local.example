GROQ_API_KEY=your_groq_api_key_here

# Resend — for waitlist storage and welcome emails
# Sign up at resend.com → API Keys → Create key
RESEND_API_KEY=your_resend_api_key_here
# resend.com → Audiences → Create audience → copy the ID
RESEND_AUDIENCE_ID=your_audience_id_here
# Once you verify a domain: "CareerCare AI <hello@yourdomain.com>"
# Until then leave blank (uses resend's onboarding@resend.dev sender)
RESEND_FROM_EMAIL=
